# Newsletter Configuration - Buttondown
EXPO_PUBLIC_BUTTONDOWN_API_KEY=your_buttondown_api_key_here

# Alternative newsletter services (commented out)
# EXPO_PUBLIC_CONVERTKIT_API_KEY=your_convertkit_api_key
# EXPO_PUBLIC_CONVERTKIT_FORM_ID=your_form_id

# EXPO_PUBLIC_MAILCHIMP_API_KEY=your_mailchimp_api_key
# EXPO_PUBLIC_MAILCHIMP_AUDIENCE_ID=your_audience_id

# Custom backend (if you build your own later)
# EXPO_PUBLIC_NEWSLETTER_API_KEY=your_custom_api_key
# EXPO_PUBLIC_NEWSLETTER_API_URL=https://your-api.com

# Apple App Store Configuration (for EAS Submit)
# Get these from your Apple Developer account
APPLE_ID=your-apple-id@example.com
ASC_APP_ID=1234567890
APPLE_TEAM_ID=ABCDE12345

# Other app configurations (add as needed)
# EXPO_PUBLIC_APP_VERSION=1.0.0
# EXPO_PUBLIC_ANALYTICS_KEY=your_analytics_key
